# Basics
alias ls='ls --color=auto'
alias grep='grep --color=auto'
alias vim="nvim"
alias tetris="tetriscurses"
alias lf="source lf-wrapper"

# System Administration
alias lockkeyring="gpgconf --kill gpg-agent && faillock --reset"
alias flushdns="sudo systemd-resolve --flush-caches"

# Server
alias backup-dotfiles="${XDG_CONFIG_HOME}/yadm/backup"
alias occ="docker exec -it -u www-data nextcloud php occ"
alias mail-fail2ban="docker exec -it mailserver fail2ban-client"
alias swag-fail2ban="docker exec -it swag fail2ban-client"
alias logs="docker logs -f"
alias rcon="docker exec -it minecraft rcon-cli"

attach() {
  if docker exec "$1" which bash > /dev/null 2>&1; then
    docker exec -it "$1" bash
  else
    docker exec -it "$1" sh
  fi
}
